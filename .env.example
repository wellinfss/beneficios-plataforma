# PostgreSQL
POSTGRES_DB=beneficiostdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET_KEY=your-super-secret-key-min-32-characters-long-here
JWT_ISSUER=beneficios-plataforma
JWT_AUDIENCE=beneficios-api
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# API
API_PORT=5000
API_ENVIRONMENT=Development

# Application
APP_NAME=Beneficios Plataforma
APP_VERSION=1.0.0
