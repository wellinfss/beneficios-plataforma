{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=beneficiostdb;Username=postgres;Password=postgres;Port=5432;",
    "Redis": "redis:6379",
    "RabbitMQ": "amqp://guest:guest@rabbitmq:5672"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-min-32-characters-long-here",
    "Issuer": "beneficios-plataforma",
    "Audience": "beneficios-api",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  }
}
